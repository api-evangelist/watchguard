          "http": {
            "method": "GET",
            "url": "https://api.usa.cloud.watchguard.com/rest/platform/operator-mgmt/v1/OperatorsByAccountId",
            "params": [
              {
                "name": "account_id",
                "value": "",
                "type": "query",
                "description": "WatchGuard Cloud account ID."
              }
            ],
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
